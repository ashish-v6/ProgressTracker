# Production: use a relative path so requests route through the Vercel proxy.
# The vercel.json rewrite forwards /api/* to the Render backend server-side.
# This keeps the refreshToken cookie first-party (same origin = vercel.app).
VITE_API_URL=/api

# For local development, create a .env.local file (gitignored by Vite) with:
# VITE_API_URL=http://localhost:5000/api
# .env.local takes priority over .env, so local dev hits localhost directly.

